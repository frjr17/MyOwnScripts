# Example environment variables for repository
# Copy this file to ".env" and fill in your values.
# GITHUB_NAME: Your full name (e.g., Jane Doe)
# GITHUB_USERNAME: Your GitHub username (e.g., janedoe)
# GITHUB_EMAIL: Email associated with your GitHub account (e.g., jane@example.com)

GITHUB_NAME=
GITHUB_USERNAME=
GITHUB_EMAIL=