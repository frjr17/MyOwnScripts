From ecfae59297cf1221d85ccdf8113192a4b74abcb1 Mon Sep 17 00:00:00 2001
From: Local Mutter Build <local@localhost>
Date: Thu, 16 Jul 2026 20:35:27 -0500
Subject: [PATCH] color: Coalesce generated device profile requests

---
 src/backends/meta-color-store.c    | 112 ++++++++++++------------
 src/tests/color-management-tests.c | 135 +++++++++++++++++++++++++++++
 2 files changed, 191 insertions(+), 56 deletions(-)

diff --git a/src/backends/meta-color-store.c b/src/backends/meta-color-store.c
index 5189f71..58ed44a 100644
--- a/src/backends/meta-color-store.c
+++ b/src/backends/meta-color-store.c
@@ -45,12 +45,6 @@ struct _MetaColorStore
   GCancellable *cancellable;
 };
 
-typedef struct
-{
-  MetaColorStore *color_store;
-  char *key;
-} EnsureDeviceProfileData;
-
 G_DEFINE_TYPE (MetaColorStore, meta_color_store,
                G_TYPE_OBJECT)
 
@@ -441,7 +435,8 @@ meta_color_store_new (MetaColorManager *color_manager)
   color_store->device_profiles =
     g_hash_table_new_full (g_str_hash, g_str_equal, g_free, g_object_unref);
   color_store->pending_device_profiles =
-    g_hash_table_new_full (g_str_hash, g_str_equal, g_free, NULL);
+    g_hash_table_new_full (g_str_hash, g_str_equal, g_free,
+                           (GDestroyNotify) g_ptr_array_unref);
   color_store->pending_local_profiles =
     g_hash_table_new_full (g_str_hash, g_str_equal, g_free, g_object_unref);
 
@@ -451,41 +446,56 @@ meta_color_store_new (MetaColorManager *color_manager)
   return color_store;
 }
 
-static void
-ensure_device_profile_data_free (EnsureDeviceProfileData *data)
-{
-  g_free (data->key);
-  g_free (data);
-}
-
 static void
 on_profile_generated (GObject      *source_object,
                       GAsyncResult *res,
                       gpointer      user_data)
 {
   MetaColorDevice *color_device = META_COLOR_DEVICE (source_object);
-  g_autoptr (GTask) task = G_TASK (user_data);
+  MetaColorStore *color_store = META_COLOR_STORE (user_data);
+  g_autoptr (GPtrArray) tasks = NULL;
+  g_autofree char *key = NULL;
   g_autoptr (GError) error = NULL;
-  MetaColorProfile *color_profile;
+  g_autoptr (MetaColorProfile) color_profile = NULL;
+  size_t i;
+
+  if (!g_hash_table_steal_extended (color_store->pending_device_profiles,
+                                    meta_color_device_get_id (color_device),
+                                    (gpointer *) &key,
+                                    (gpointer *) &tasks))
+    g_assert_not_reached ();
 
   color_profile = meta_color_device_generate_profile_finish (color_device,
                                                              res,
                                                              &error);
-  if (!color_profile)
+  if (color_profile)
     {
-      if (g_error_matches (error, G_IO_ERROR, G_IO_ERROR_CANCELLED))
-        {
-          g_task_return_error (task, g_steal_pointer (&error));
-          return;
-        }
-
-      g_task_return_new_error (task, G_IO_ERROR, G_IO_ERROR_FAILED,
-                               "Failed to generate and read ICC profile: %s",
-                               error->message);
-      return;
+      g_hash_table_insert (color_store->device_profiles,
+                           g_strdup (key),
+                           g_object_ref (color_profile));
+      g_hash_table_insert (color_store->profiles,
+                           g_strdup (meta_color_profile_get_id (color_profile)),
+                           g_object_ref (color_profile));
+    }
+  else if (!g_error_matches (error, G_IO_ERROR, G_IO_ERROR_CANCELLED))
+    {
+      g_prefix_error (&error, "Failed to generate and read ICC profile: ");
     }
 
-  g_task_return_pointer (task, color_profile, g_object_unref);
+  for (i = 0; i < tasks->len; i++)
+    {
+      GTask *task = g_ptr_array_index (tasks, i);
+
+      if (g_task_return_error_if_cancelled (task))
+        continue;
+
+      if (color_profile)
+        g_task_return_pointer (task,
+                               g_object_ref (color_profile),
+                               g_object_unref);
+      else
+        g_task_return_error (task, g_error_copy (error));
+    }
 }
 
 gboolean
@@ -498,9 +508,10 @@ meta_color_store_ensure_device_profile (MetaColorStore      *color_store,
   MetaMonitor *monitor;
   const char *edid_checksum_md5;
   g_autoptr (GTask) task = NULL;
+  GPtrArray *tasks;
+  const char *key;
   g_autofree char *file_name = NULL;
   g_autofree char *file_path = NULL;
-  EnsureDeviceProfileData *data;
   MetaColorProfile *color_profile;
 
   monitor = meta_color_device_get_monitor (color_device);
@@ -511,17 +522,16 @@ meta_color_store_ensure_device_profile (MetaColorStore      *color_store,
   task = g_task_new (G_OBJECT (color_store), cancellable, callback, user_data);
   g_task_set_source_tag (task, meta_color_store_ensure_device_profile);
 
+  if (g_task_return_error_if_cancelled (task))
+    return TRUE;
+
   file_name = g_strdup_printf ("edid-%s.icc", edid_checksum_md5);
   file_path = g_build_filename (g_get_user_data_dir (),
                                 "icc", file_name, NULL);
 
-  data = g_new0 (EnsureDeviceProfileData, 1);
-  data->color_store = color_store;
-  data->key = g_strdup (meta_color_device_get_id (color_device));
-  g_task_set_task_data (task, data,
-                        (GDestroyNotify) ensure_device_profile_data_free);
+  key = meta_color_device_get_id (color_device);
 
-  color_profile = g_hash_table_lookup (color_store->device_profiles, data->key);
+  color_profile = g_hash_table_lookup (color_store->device_profiles, key);
   if (color_profile)
     {
       g_task_return_pointer (task,
@@ -530,20 +540,24 @@ meta_color_store_ensure_device_profile (MetaColorStore      *color_store,
       return TRUE;
     }
 
-  if (g_hash_table_contains (color_store->pending_device_profiles, data->key))
+  tasks = g_hash_table_lookup (color_store->pending_device_profiles, key);
+  if (tasks)
     {
-      g_task_return_new_error (task, G_IO_ERROR, G_IO_ERROR_FAILED,
-                               "Profile generation already in progress");
+      g_ptr_array_add (tasks, g_steal_pointer (&task));
       return TRUE;
     }
 
-  g_hash_table_add (color_store->pending_device_profiles, g_strdup (data->key));
+  tasks = g_ptr_array_new_with_free_func (g_object_unref);
+  g_ptr_array_add (tasks, g_steal_pointer (&task));
+  g_hash_table_insert (color_store->pending_device_profiles,
+                       g_strdup (key),
+                       tasks);
 
   meta_color_device_generate_profile (color_device,
                                       file_path,
-                                      cancellable,
+                                      color_store->cancellable,
                                       on_profile_generated,
-                                      g_steal_pointer (&task));
+                                      color_store);
   return TRUE;
 }
 
@@ -553,25 +567,11 @@ meta_color_store_ensure_device_profile_finish (MetaColorStore  *color_store,
                                                GError         **error)
 {
   GTask *task = G_TASK (res);
-  EnsureDeviceProfileData *data = g_task_get_task_data (task);
-  g_autoptr (MetaColorProfile) color_profile = NULL;
 
   g_assert (g_task_get_source_tag (task) ==
             meta_color_store_ensure_device_profile);
 
-  g_hash_table_remove (color_store->pending_device_profiles, data->key);
-
-  color_profile = g_task_propagate_pointer (task, error);
-  if (!color_profile)
-    return NULL;
-
-  g_hash_table_insert (color_store->device_profiles,
-                       g_steal_pointer (&data->key),
-                       g_object_ref (color_profile));
-  g_hash_table_insert (color_store->profiles,
-                       g_strdup (meta_color_profile_get_id (color_profile)),
-                       g_object_ref (color_profile));
-  return color_profile;
+  return g_task_propagate_pointer (task, error);
 }
 
 typedef struct
diff --git a/src/tests/color-management-tests.c b/src/tests/color-management-tests.c
index 1074b45..b1e174e 100644
--- a/src/tests/color-management-tests.c
+++ b/src/tests/color-management-tests.c
@@ -1404,6 +1404,137 @@ meta_test_color_management_night_light_uncalibrated (void)
                       crtc_test->gamma.size);
 }
 
+static void
+assert_identical_monitor_gamma (MetaMonitor *monitor1,
+                                MetaMonitor *monitor2)
+{
+  MetaOutput *output1 = meta_monitor_get_main_output (monitor1);
+  MetaOutput *output2 = meta_monitor_get_main_output (monitor2);
+  MetaCrtcTest *crtc1 =
+    META_CRTC_TEST (meta_output_get_assigned_crtc (output1));
+  MetaCrtcTest *crtc2 =
+    META_CRTC_TEST (meta_output_get_assigned_crtc (output2));
+  size_t last;
+
+  g_assert_cmpuint (crtc1->gamma.size, >, 0);
+  g_assert_cmpuint (crtc1->gamma.size, ==, crtc2->gamma.size);
+  last = crtc1->gamma.size - 1;
+  assert_gamma_array (crtc1->gamma.red, crtc2->gamma.red,
+                      crtc1->gamma.size);
+  assert_gamma_array (crtc1->gamma.green, crtc2->gamma.green,
+                      crtc1->gamma.size);
+  assert_gamma_array (crtc1->gamma.blue, crtc2->gamma.blue,
+                      crtc1->gamma.size);
+  g_assert_cmpuint (crtc1->gamma.green[last], <, crtc1->gamma.red[last]);
+  g_assert_cmpuint (crtc1->gamma.blue[last], <, crtc1->gamma.green[last]);
+}
+
+static void
+test_identical_monitor_night_light (const char *serial)
+{
+  MetaBackend *backend = meta_context_get_backend (test_context);
+  MetaMonitorManager *monitor_manager =
+    meta_backend_get_monitor_manager (backend);
+  MetaMonitorManagerTest *monitor_manager_test =
+    META_MONITOR_MANAGER_TEST (monitor_manager);
+  MetaColorManager *color_manager =
+    meta_backend_get_color_manager (backend);
+  MonitorTestCaseSetup test_case_setup = base_monitor_setup;
+  MetaMonitorTestSetup *test_setup;
+  MetaMonitor *monitor1;
+  MetaMonitor *monitor2;
+  MetaColorDevice *color_device1;
+  MetaColorDevice *color_device2;
+  MetaColorProfile *color_profile;
+  const char *color_profiles[1];
+  GList *monitors;
+  gboolean device1_changed = TRUE;
+  gboolean device2_changed = TRUE;
+  gulong device1_handler_id;
+  gulong device2_handler_id;
+
+  test_case_setup.outputs[0].serial = serial;
+  test_case_setup.outputs[0].edid_info = ANCOR_VX239_EDID;
+  test_case_setup.outputs[0].has_edid_info = TRUE;
+  test_case_setup.outputs[1].serial = serial;
+  test_case_setup.outputs[1].edid_info = ANCOR_VX239_EDID;
+  test_case_setup.outputs[1].has_edid_info = TRUE;
+  test_case_setup.n_outputs = 2;
+
+  test_setup = meta_create_monitor_test_setup (backend, &test_case_setup,
+                                               MONITOR_TEST_FLAG_NO_STORED);
+  meta_monitor_manager_test_emulate_hotplug (monitor_manager_test, test_setup);
+
+  monitors = meta_monitor_manager_get_monitors (monitor_manager);
+  g_assert_cmpuint (g_list_length (monitors), ==, 2);
+  monitor1 = monitors->data;
+  monitor2 = monitors->next->data;
+  color_device1 = meta_color_manager_get_color_device (color_manager, monitor1);
+  color_device2 = meta_color_manager_get_color_device (color_manager, monitor2);
+  g_assert_nonnull (color_device1);
+  g_assert_nonnull (color_device2);
+  g_assert_true (color_device1 != color_device2);
+  g_assert_cmpstr (meta_color_device_get_id (color_device1), ==,
+                   meta_color_device_get_id (color_device2));
+
+  while (!meta_color_device_is_ready (color_device1) ||
+         !meta_color_device_is_ready (color_device2))
+    g_main_context_iteration (NULL, TRUE);
+
+  color_profile = meta_color_device_get_device_profile (color_device1);
+  g_assert_nonnull (color_profile);
+  g_assert_true (color_profile ==
+                 meta_color_device_get_device_profile (color_device2));
+
+  color_profiles[0] = meta_color_profile_get_id (color_profile);
+  set_colord_device_profiles (meta_color_device_get_id (color_device1),
+                              color_profiles, G_N_ELEMENTS (color_profiles));
+  wait_for_profile_assigned (color_device1, color_profiles[0]);
+  wait_for_profile_assigned (color_device2, color_profiles[0]);
+
+  device1_handler_id =
+    g_signal_connect (color_device1, "calibration-changed",
+                      G_CALLBACK (on_device_calibration_changed),
+                      &device1_changed);
+  device2_handler_id =
+    g_signal_connect (color_device2, "calibration-changed",
+                      G_CALLBACK (on_device_calibration_changed),
+                      &device2_changed);
+
+  set_night_light_temperature (6501);
+  while (device1_changed || device2_changed)
+    g_main_context_iteration (NULL, TRUE);
+
+  device1_changed = TRUE;
+  device2_changed = TRUE;
+  set_night_light_temperature (3305);
+  while (device1_changed || device2_changed)
+    g_main_context_iteration (NULL, TRUE);
+
+  g_signal_handler_disconnect (color_device1, device1_handler_id);
+  g_signal_handler_disconnect (color_device2, device2_handler_id);
+  assert_identical_monitor_gamma (monitor1, monitor2);
+
+  test_setup = meta_create_monitor_test_setup (backend, &test_case_setup,
+                                               MONITOR_TEST_FLAG_NO_STORED);
+  meta_monitor_manager_test_emulate_hotplug (monitor_manager_test, test_setup);
+
+  monitors = meta_monitor_manager_get_monitors (monitor_manager);
+  assert_identical_monitor_gamma (monitors->data, monitors->next->data);
+}
+
+static void
+meta_test_color_management_night_light_identical_no_serial (void)
+{
+  test_identical_monitor_night_light ("");
+}
+
+static void
+meta_test_color_management_night_light_identical_zero_serial (void)
+{
+  test_identical_monitor_night_light ("0x00000000");
+}
+
 static MetaMonitorTestSetup *
 create_stage_view_test_setup (MetaBackend *backend)
 {
@@ -1464,6 +1595,10 @@ init_tests (void)
                   meta_test_color_management_night_light_calibrated);
   add_color_test ("/color-management/night-light/uncalibrated",
                   meta_test_color_management_night_light_uncalibrated);
+  add_color_test ("/color-management/night-light/identical-no-serial",
+                  meta_test_color_management_night_light_identical_no_serial);
+  add_color_test ("/color-management/night-light/identical-zero-serial",
+                  meta_test_color_management_night_light_identical_zero_serial);
 }
 
